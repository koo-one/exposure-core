{
  "name": "exposure-core",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "start:web": "pnpm --filter web start",
    "lint:web": "pnpm --filter web lint",
    "graphs:dev": "tsx --tsconfig server/tsconfig.fixtures.json --env-file=.env.local server/fixtures/scripts/graphs-all.ts",
    "graphs:prod": "tsx --tsconfig server/tsconfig.json --env-file=.env.production server/src/exposure/graphs-upload.ts",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "test": "vitest run --config apps/web/vitest.config.ts",
    "test:watch": "vitest --config apps/web/vitest.config.ts"
  },
  "lint-staged": {
    "**/*.{js,mjs,ts,tsx,json,md}": "prettier --write",
    "**/*.{ts,tsx}": "eslint --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0",
    "@vercel/blob": "^2.0.0",
    "graphql": "^16.12.0",
    "graphql-request": "^7.4.0",
    "viem": "^2.45.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.3",
    "@vercel/node": "^5.3.10",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vitest": "^4.1.0"
  }
}
